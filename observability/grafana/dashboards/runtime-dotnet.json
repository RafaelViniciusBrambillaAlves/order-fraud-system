  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Memory & GC heap",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GC heap size by generation",
      "description": "Tamanho do heap do .NET por geração de GC. Gen0 = objetos novos (cresce rápido, coletado com frequência). Gen2 crescendo sem ser coletado = possível memory leak.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "spanNulls": false,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "otel_process_runtime_dotnet_gc_heap_size_bytes{exported_job=\"order-service\"}",
          "legendFormat": "gen {{generation}}",
          "instant": false,
          "range": true,
          "refId": "A",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GC collections rate",
      "description": "Quantas coletas de GC por segundo por geração. Gen2 coletando muito = os objetos estão sobrevivendo tempo demais, o que pode indicar referências desnecessárias sendo mantidas.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "drawStyle": "line",
            "spanNulls": false,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (generation) (rate(otel_process_runtime_dotnet_gc_collections_count_total{exported_job=\"order-service\"}[5m]))",
          "legendFormat": "gen {{generation}}",
          "instant": false,
          "range": true,
          "refId": "A",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC pause ratio P95",
      "description": "Fração do tempo total que o processo fica pausado pelo GC. Acima de 2% começa a impactar a latência HTTP. Acima de 5% é um problema sério.",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
